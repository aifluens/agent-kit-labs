{
  "name": "agent-kit-labs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Run the AIFluensLab learning labs on your own machine with your own provider key (BYOK). The lab code is identical to what the platform shows.",
  "license": "MIT",
  "scripts": {
    "m1": "tsx --env-file-if-exists=.env labs/m1-llm-foundations/agent.ts",
    "m2": "tsx --env-file-if-exists=.env labs/m2-tool-use/agent.ts",
    "m4": "tsx --env-file-if-exists=.env labs/m4-vector-search-rag/retriever.ts",
    "m5:mcp": "tsx --env-file-if-exists=.env labs/m5-mcp-tools/agent-mcp.ts",
    "m5:http": "tsx --env-file-if-exists=.env labs/m5-mcp-tools/agent-http.ts",
    "m9": "tsx --env-file-if-exists=.env labs/m9-agent-to-agent/agent.ts",
    "servers": "node --env-file-if-exists=.env servers/helpdesk.mjs",
    "ingest": "node --env-file-if-exists=.env node_modules/@aifluens/agent-kit/dist/bin/ingest.js ./docs/*.md --kb 1"
  },
  "dependencies": {
    "@aifluens/agent-kit": "0.2.0",
    "@langchain/core": "^0.3.58",
    "@langchain/openai": "^0.3.17",
    "@xenova/transformers": "^2.17.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.12"
  }
}