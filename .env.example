# --- Provider selection + keys (BYOK) --------------------------------------
# Which LLM provider agent-kit uses. Set this explicitly — it is NOT inferred
# from the model name. Valid values:
#   anthropic | openai | google | bedrock | azure-openai | vertex
LLM_PROVIDER=openai

# Set the key for the provider you chose above. You can fill in either or both.
#   - LLM_PROVIDER=openai     → OPENAI_API_KEY
#   - LLM_PROVIDER=anthropic  → ANTHROPIC_API_KEY
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Which model id the labs use (provider is set by LLM_PROVIDER above).
#   LAB_MODEL=gpt-4o-mini    (default — pair with LLM_PROVIDER=openai)
#   LAB_MODEL=claude-sonnet  (pair with LLM_PROVIDER=anthropic)
# Leave unset to use the default in labs/_shared/model.ts (gpt-4o-mini).
LAB_MODEL=gpt-4o-mini

# --- M4 (RAG) only ---------------------------------------------------------
# Postgres + pgvector connection. Matches the docker run command in the README.
DATABASE_URL=postgres://postgres:pw@localhost:5432/postgres
# Knowledge-base id the Retriever searches (the labs default to 1).
AGENT_KIT_KB_ID=1

# --- M5 (MCP / HTTP) only --------------------------------------------------
# Points the labs at the local Help Desk servers (npm run servers).
AGENT_KIT_CONNECTIONS={"helpdesk-sandbox":{"kind":"mcp","url":"http://localhost:8000/mcp"},"helpdesk-http":{"kind":"http","url":"http://localhost:8001"}}
